{
    "name": "rabbitmq-sms/shared",
    "description": "Código compartido entre los actores del sistema SMS: conexiones, modelos y repositorios.",
    "type": "library",
    "require": {
        "php": ">=8.2",
        "php-amqplib/php-amqplib": "^3.7",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "RabbitmqSms\\Shared\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RabbitmqSms\\Shared\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
