{
    "name": "rabbitmq-sms/intermediario",
    "description": "Intermediario SMS: enruta mensajes a cola directa o delayed según las reglas de negocio.",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "php-amqplib/php-amqplib": "^3.7",
        "psr/log": "^3.0",
        "monolog/monolog": "^3.0",
        "rabbitmq-sms/shared": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "RabbitmqSms\\Intermediario\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RabbitmqSms\\Intermediario\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../shared"
        }
    ],
    "config": {
        "optimize-autoloader": true
    }
}
